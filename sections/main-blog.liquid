<div class="blog-header">
  <h1 class="blog-header__title reveal">{{ 'blogs.general.title' | t }}</h1>
  <p class="blog-header__subtitle reveal">{{ 'blogs.general.subtitle' | t }}</p>
</div>

<!-- Tag Filter -->
<div class="blog-tags reveal">
  <a
    class="blog-tag{% unless current_tags %} is-active{% endunless %}"
    href="{{ blog.url }}"
  >{{ 'blogs.tags.all' | t }}</a>

  {%- for tag in blog.all_tags -%}
    <a
      class="blog-tag{% if current_tags contains tag %} is-active{% endif %}"
      href="{{ blog.url }}/tagged/{{ tag | handle }}"
    >{{ tag }}</a>
  {%- else -%}
    <a class="blog-tag" href="{{ blog.url }}/tagged/deep-dive">{{ 'blogs.tags.deep_dive' | t }}</a>
    <a class="blog-tag" href="{{ blog.url }}/tagged/educational">{{ 'blogs.tags.educational' | t }}</a>
    <a class="blog-tag" href="{{ blog.url }}/tagged/provenance">{{ 'blogs.tags.provenance' | t }}</a>
  {%- endfor -%}
</div>

<!-- Article List -->
<div class="blog-list">
  {%- paginate blog.articles by 8 -%}
    {%- for article in blog.articles -%}
      <a class="blog-card reveal" href="{{ article.url }}">
        {%- if article.tags.size > 0 -%}
          <span class="blog-card__tag">{{ article.tags.first }}</span>
        {%- endif -%}

        <h2 class="blog-card__title">{{ article.title }}</h2>

        {%- if article.excerpt -%}
          <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 160 }}</p>
        {%- endif -%}

        <span class="blog-card__meta">
          {{ article.published_at | date: '%B %-d, %Y' }}
        </span>
      </a>
    {%- else -%}
      {%- comment -%} Demo articles — shown when no blog posts exist yet {%- endcomment -%}

      <a class="blog-card reveal" href="#">
        <span class="blog-card__tag">Deep-Dive</span>
        <h2 class="blog-card__title">Why CGC 9.8 Isn't Always the Right Grade to Buy</h2>
        <p class="blog-card__excerpt">The difference between a 9.6 and a 9.8 is often invisible to the naked eye — but the price gap can exceed two thousand dollars. Here's when the premium is justified, and when it isn't.</p>
        <span class="blog-card__meta">February 15, 2026</span>
      </a>

      <a class="blog-card reveal" href="#">
        <span class="blog-card__tag">Educational</span>
        <h2 class="blog-card__title">The Silver Age Key Issue Index: What Actually Holds Value in 2026</h2>
        <p class="blog-card__excerpt">Not every first appearance is equal. We ranked 40 Silver Age keys by price stability, cultural relevance, and collector demand — and a few of the results are genuinely surprising.</p>
        <span class="blog-card__meta">February 8, 2026</span>
      </a>

      <a class="blog-card reveal" href="#">
        <span class="blog-card__tag">Provenance</span>
        <h2 class="blog-card__title">On the Trail of a Pedigree Collection: Six Months in Denver</h2>
        <p class="blog-card__excerpt">A retired schoolteacher. A storage unit in suburban Colorado. And somewhere inside it, an intact run of early Marvels that hadn't been touched since 1971. The story of how we found them.</p>
        <span class="blog-card__meta">January 27, 2026</span>
      </a>

      <a class="blog-card reveal" href="#">
        <span class="blog-card__tag">Educational</span>
        <h2 class="blog-card__title">Raw vs. Slabbed: A Practical Guide for Serious Collectors</h2>
        <p class="blog-card__excerpt">Graded slabs provide certainty. Raw copies offer intimacy. The right choice depends on what you're optimizing for — and most collectors are optimizing for the wrong thing.</p>
        <span class="blog-card__meta">January 14, 2026</span>
      </a>

      <a class="blog-card reveal" href="#">
        <span class="blog-card__tag">Deep-Dive</span>
        <h2 class="blog-card__title">The Anatomy of a Key Issue: Amazing Fantasy #15</h2>
        <p class="blog-card__excerpt">Published in August 1962 as a try-out vehicle the editors expected to cancel, Amazing Fantasy #15 became the most consequential comic book of the twentieth century. Here is the full history.</p>
        <span class="blog-card__meta">December 30, 2025</span>
      </a>

    {%- endfor -%}

    {%- if paginate.pages > 1 -%}
      <div class="blog-pagination">
        {%- if paginate.previous -%}
          <a class="blog-pagination__link" href="{{ paginate.previous.url }}">
            {{ 'blogs.pagination.newer' | t }}
          </a>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if paginate.next -%}
          <a class="blog-pagination__link" href="{{ paginate.next.url }}">
            {{ 'blogs.pagination.older' | t }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": []
}
{% endschema %}
