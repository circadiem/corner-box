<section class="manifest">
  <div class="manifest__inner">

    <div class="manifest__header reveal">
      <div>
        <span class="manifest__drop-number">
          {{- settings.current_drop_number | default: 'Drop 001' -}}
        </span>
        <span class="manifest__label">
          {{- settings.current_drop_theme | default: 'The Silver Age Vaults' -}}
        </span>
      </div>
      <a class="manifest__link" href="{{ routes.collections_url }}/current-drop">
        Enter the Vault &rarr;
      </a>
    </div>

    {%- if settings.current_drop_collection != blank -%}
      {%- assign drop_collection = collections[settings.current_drop_collection] -%}
      {%- for product in drop_collection.products limit: 8 -%}
        <a class="manifest__item reveal" href="{{ product.url }}">
          <div class="manifest__item-info">
            <p class="manifest__item-title">{{ product.title }}</p>
            <p class="manifest__item-meta">
              {%- if product.metafields.custom.publisher -%}
                {{ product.metafields.custom.publisher }}
              {%- endif -%}
              {%- if product.metafields.custom.grade -%}
                &nbsp;&middot;&nbsp;{{ product.metafields.custom.grade }}
              {%- endif -%}
            </p>
          </div>
          <span class="manifest__item-price{% unless product.available %} manifest__item-price--sold{% endunless %}">
            {%- unless product.available -%}
              {{ 'products.product.sold_out' | t }}
            {%- else -%}
              {{ product.price | money }}
            {%- endunless -%}
          </span>
        </a>
      {%- endfor -%}
    {%- else -%}

      {%- comment -%} Demo inventory — Drop 001: The Silver Age Vaults {%- endcomment -%}
      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Amazing Fantasy #15 &mdash; 1st Appearance of Spider-Man</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Aug 1962 &middot; CGC 2.0</p>
        </div>
        <span class="manifest__item-price manifest__item-price--sold">SOLD</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Fantastic Four #4 &mdash; 1st Silver Age Sub-Mariner</p>
          <p class="manifest__item-meta">Marvel Comics &middot; May 1962 &middot; CGC 5.5</p>
        </div>
        <span class="manifest__item-price">$1,850</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Journey into Mystery #83 &mdash; 1st Appearance of Thor</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Aug 1962 &middot; CGC 3.0</p>
        </div>
        <span class="manifest__item-price manifest__item-price--sold">SOLD</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">X-Men #1 &mdash; 1st Appearance of the X-Men &amp; Magneto</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Sep 1963 &middot; CGC 4.0</p>
        </div>
        <span class="manifest__item-price">$2,400</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Tales of Suspense #39 &mdash; 1st Appearance of Iron Man</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Mar 1963 &middot; CGC 3.5</p>
        </div>
        <span class="manifest__item-price manifest__item-price--sold">SOLD</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Brave and the Bold #28 &mdash; 1st Appearance of the Justice League</p>
          <p class="manifest__item-meta">DC Comics &middot; Feb 1960 &middot; CGC 4.5</p>
        </div>
        <span class="manifest__item-price">$3,100</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Strange Tales #110 &mdash; 1st Appearance of Doctor Strange</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Jul 1963 &middot; CGC 6.0</p>
        </div>
        <span class="manifest__item-price">$1,650</span>
      </a>

      <a class="manifest__item reveal" href="#">
        <div class="manifest__item-info">
          <p class="manifest__item-title">Amazing Spider-Man #1 &mdash; Spider-Man Meets the Fantastic Four</p>
          <p class="manifest__item-meta">Marvel Comics &middot; Mar 1963 &middot; CGC 3.0</p>
        </div>
        <span class="manifest__item-price">$3,950</span>
      </a>

    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Homepage Manifest",
  "settings": []
}
{% endschema %}
