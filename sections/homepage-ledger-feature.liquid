<section class="ledger-feature">
  <div class="ledger-feature__inner">
    <span class="ledger-feature__label reveal">
      {{- settings.featured_article_label | default: 'From The Ledger' -}}
    </span>

    {%- if settings.featured_article_url != blank -%}
      <a href="{{ settings.featured_article_url }}">
        <h2 class="ledger-feature__title reveal">
          {{- settings.featured_article_title | default: "Why CGC 9.8 Isn't Always the Right Grade to Buy" -}}
        </h2>
      </a>
    {%- else -%}
      <h2 class="ledger-feature__title reveal">
        {{- settings.featured_article_title | default: "Why CGC 9.8 Isn't Always the Right Grade to Buy" -}}
      </h2>
    {%- endif -%}

    <p class="ledger-feature__preview reveal">
      {{- settings.featured_article_preview | default: "The difference between a 9.6 and a 9.8 is often invisible to the naked eye — but the price gap can exceed two thousand dollars. Here's when the premium is justified, and when it isn't." -}}
    </p>

    {%- if settings.featured_article_url != blank -%}
      <a class="ledger-feature__read reveal" href="{{ settings.featured_article_url }}">
        Read &rarr;
      </a>
    {%- else -%}
      <a class="ledger-feature__read reveal" href="{{ routes.blogs_url }}/the-ledger">
        View The Ledger &rarr;
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Ledger Feature",
  "settings": []
}
{% endschema %}