<section class="hero" id="Hero">
  <p class="hero__label reveal">
    {{ settings.current_drop_number | default: 'Drop 001' }}
    &nbsp;/&nbsp;
    {{ settings.current_drop_theme | default: 'The Silver Age Vaults' }}
  </p>

  <h1 class="hero__title reveal">The Vault is open.</h1>

  <div class="hero__meta reveal">
    <div class="hero__meta-item">
      <span class="hero__meta-value">{{ settings.current_drop_titles | default: 8 }}</span>
      <span class="hero__meta-label">Issues</span>
    </div>
    <div class="hero__meta-divider" aria-hidden="true"></div>
    <div class="hero__meta-item">
      <span class="hero__meta-value">{{ settings.current_drop_units | default: 5 }}</span>
      <span class="hero__meta-label">Available</span>
    </div>
    <div class="hero__meta-divider" aria-hidden="true"></div>
    <div class="hero__meta-item">
      <span class="hero__meta-value" style="color: var(--marvel-red);">3</span>
      <span class="hero__meta-label">Sold</span>
    </div>
  </div>

  <a class="hero__cta reveal" href="{{ routes.collections_url }}/current-drop">
    Enter the Vault
  </a>
</section>

{% schema %}
{
  "name": "Hero — Vault Open",
  "settings": []
}
{% endschema %}
