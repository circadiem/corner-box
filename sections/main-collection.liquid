<div class="collection-header">
  <h1 class="collection-header__title reveal">
    {{- settings.current_drop_number | default: 'Drop 001' -}}: {{- settings.current_drop_theme | default: 'The Debut' -}}
  </h1>

  {%- if collection.description != blank -%}
    <div class="collection-header__description reveal">{{ collection.description }}</div>
  {%- endif -%}

  {%- assign ledger_url = settings.current_drop_ledger_url | default: '/blogs/ledger' -%}
  <a class="collection-header__ledger-link reveal" href="{{ ledger_url }}">
    Browse The Ledger &rarr;
  </a>

  <p class="collection-header__meta reveal">
    {{ 'collections.general.items_with_count_other' | t: count: collection.products_count }}
  </p>
</div>

<div class="collection-main">
  {%- if collection.products_count > 0 -%}
    <div class="product-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="pagination reveal" style="margin-top: var(--space-xl); display: flex; justify-content: space-between; align-items: center;">
        {%- if paginate.previous -%}
          <a class="btn btn--ghost" href="{{ paginate.previous.url }}">
            &larr; {{ 'blogs.pagination.older' | t }}
          </a>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if paginate.next -%}
          <a class="btn btn--ghost" href="{{ paginate.next.url }}">
            {{ 'blogs.pagination.newer' | t }} &rarr;
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="collection-empty">
      <p>The vault is empty right now.</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
