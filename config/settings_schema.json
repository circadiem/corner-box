      {
        "type": "text",
        "id": "featured_article_title",
        "label": "Article title",
        "default": "The Anatomy of a Key Issue: Amazing Fantasy #15"
      },
      {
        "type": "textarea",
        "id": "featured_article_preview",
        "label": "Two-sentence preview",
